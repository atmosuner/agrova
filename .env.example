# Supabase (Seoul project) — copy to `.env` and fill from
# Project Settings → API: Project URL + anon (public) key
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for password-recovery redirect (must match Supabase Auth → URL allow list)
# VITE_SITE_URL=https://your-app.example.com

# Playwright: optional owner login for e2e/*.authed.spec.ts (writes e2e/.auth/owner.json; gitignored)
# E2E_OWNER_EMAIL=owner@example.com
# E2E_OWNER_PASSWORD=your-test-password

# For `pnpm supabase:gen-types` (CLI path when supabase/mcp_gentypes.json is absent)
# Project ref: substring before .supabase.co from VITE_SUPABASE_URL, or from Dashboard → Settings → General
# SUPABASE_PROJECT_REF=your_ref
# Personal access token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=your_token

# Web Push (VAPID) — not for Vite. To push keys + redeploy functions in one step:
#   1) Create a personal access token: https://supabase.com/dashboard/account/tokens
#   2) Add here: SUPABASE_ACCESS_TOKEN=sbp_...  (optional: VAPID_SUBJECT=mailto:you@example.com)
#      If omitted, `pnpm vapid:push-secrets` can read the same token from `.cursor/mcp.json` (supabase server env).
#   3) pnpm vapid:push-secrets
# Manual path: `pnpm vapid:keys` or see docs/operations/vapid-and-web-push.md
