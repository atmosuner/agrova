# Supabase (Seoul project) — copy to `.env` and fill from
# Project Settings → API: Project URL + anon (public) key
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Playwright: optional owner login for e2e/*.authed.spec.ts (writes e2e/.auth/owner.json; gitignored)
# E2E_OWNER_EMAIL=owner@example.com
# E2E_OWNER_PASSWORD=your-test-password

# For `pnpm supabase:gen-types` (CLI path when supabase/mcp_gentypes.json is absent)
# Project ref: substring before .supabase.co from VITE_SUPABASE_URL, or from Dashboard → Settings → General
# SUPABASE_PROJECT_REF=your_ref
# Personal access token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=your_token
